# ==============================
# Core AI (optional but recommended)
# ==============================
# If missing, the app uses deterministic fallback adaptation.
GEMINI_API_KEY="your_gemini_api_key"

# ==============================
# Facebook (required for live Facebook publishing)
# ==============================
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"
FACEBOOK_PAGE_ID="your_facebook_page_id"
FACEBOOK_PAGE_TOKEN="your_facebook_page_access_token"

# ==============================
# Instagram (required for live Instagram publishing)
# ==============================
INSTAGRAM_ACCESS_TOKEN="your_instagram_access_token"
INSTAGRAM_BUSINESS_ID="your_instagram_business_account_id"

# ==============================
# Twitter / X (required for live Twitter publishing)
# ==============================
TWITTER_API_KEY="your_twitter_api_key"
TWITTER_API_SECRET="your_twitter_api_secret"
TWITTER_ACCESS_TOKEN="your_twitter_access_token"
TWITTER_ACCESS_SECRET="your_twitter_access_secret"

# ==============================
# LinkedIn
# ==============================
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
LINKEDIN_ACCESS_TOKEN="your_linkedin_access_token"

# ==============================
# YouTube
# ==============================
YOUTUBE_API_KEY="your_youtube_api_key"
YOUTUBE_CLIENT_ID="your_youtube_client_id"
YOUTUBE_CLIENT_SECRET="your_youtube_client_secret"

# ==============================
# Blogger
# ==============================
BLOGGER_API_KEY="your_blogger_api_key"
BLOGGER_BLOG_ID="your_blogger_blog_id"

# ==============================
# Medium
# ==============================
MEDIUM_INTEGRATION_TOKEN="your_medium_integration_token"

# ==============================
# Pinterest
# ==============================
PINTEREST_ACCESS_TOKEN="your_pinterest_access_token"

# ==============================
# TikTok
# ==============================
TIKTOK_ACCESS_TOKEN="your_tiktok_access_token"

# ==============================
# Snapchat
# ==============================
SNAPCHAT_ACCESS_TOKEN="your_snapchat_access_token"

# ==============================
# Reddit
# ==============================
REDDIT_CLIENT_ID="your_reddit_client_id"
REDDIT_CLIENT_SECRET="your_reddit_client_secret"
REDDIT_USERNAME="your_reddit_username"
REDDIT_PASSWORD="your_reddit_password"

# ==============================
# Quora (draft generation only)
# ==============================
QUORA_SESSION_COOKIE="your_quora_session_cookie"

# ==============================
# Optional app behavior
# ==============================
CONTENTFORGE_DEBUG="false"
